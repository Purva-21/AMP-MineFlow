/*
 * Test profile — minimal resources for CI/CD
 */
params {
    input  = "${projectDir}/test_data/test_assembly.fasta"
    outdir = "${projectDir}/test_results"
    top_n  = 10
}

process {
    withLabel: 'process_low'    { cpus = 1; memory = '2.GB'; time = '30.min' }
    withLabel: 'process_medium' { cpus = 2; memory = '4.GB'; time = '1.h' }
    withLabel: 'process_high'   { cpus = 2; memory = '4.GB'; time = '1.h' }
}
